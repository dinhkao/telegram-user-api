# Get these from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Your Telegram phone number (international format)
PHONE=+84123456789

# The chat to monitor (username, invite link, or numeric chat ID)
# Examples: @telegram, https://t.me/joinchat/xxxxx, -1001234567890
TARGET_CHAT=@telegram

# Web server port
PORT=8090

# Group chat to auto-reply "yes"
GROUP_ID=-5005855529

# Fireworks API key for pi CLI
FIREWORKS_API_KEY=your_fireworks_key_here

# AI backend: "pi" (CLI with tools: bash, read, write, web search)
#              "fireworks" (direct API, chat only, no tools)
AI_BACKEND=pi

# Logging: DEBUG, INFO, WARNING, ERROR (default: DEBUG)
LOG_LEVEL=DEBUG
# Optional: write logs to rotating file (default: none, console only)
# LOG_FILE=server.log

# --- Database engine (xem docs/postgres-migration.md) ---
# 'sqlite' (mặc định, không cần Postgres) | 'postgres'
DB_ENGINE=sqlite
# Chỉ dùng khi DB_ENGINE=postgres. DSN tới Postgres giữ app.db đã migrate.
# DATABASE_URL=postgresql://letrang:letrang@localhost:5432/app
